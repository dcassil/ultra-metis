{
  "id": "data-pipeline",
  "title": "Event-Driven Data Pipeline",
  "description": "An architecture-sensitive scenario that rewards strong boundary discipline, layered processing stages, and deterministic error handling. Tests whether the agent creates clean stage boundaries, proper error types, and comprehensive validation.",
  "documents": {
    "vision": "vision.md",
    "specification": "spec.md",
    "seed_initiatives": [
      "ingestion-initiative.md",
      "enrichment-initiative.md"
    ]
  },
  "expectations": {
    "benchmark_tracks": [
      "document_generation",
      "decomposition",
      "build_outcome"
    ],
    "required_document_roles": [
      "vision",
      "initiative",
      "task"
    ],
    "architecture_focus": [
      "pipeline stage isolation",
      "error handling boundaries",
      "typed event schema",
      "backpressure and retry"
    ]
  },
  "run_rules": {
    "token_budget": 500000,
    "time_budget_secs": 600,
    "max_consecutive_failures": 3,
    "allowed_tool_surfaces": ["mcp", "cli"]
  },
  "expected_outputs": {
    "required_docs": [
      {
        "role": "initiative",
        "min_count": 3,
        "required_sections": ["Context", "Goals"]
      },
      {
        "role": "task",
        "min_count": 6,
        "required_sections": ["Objective", "Acceptance Criteria"]
      }
    ],
    "expected_hierarchy": [
      {
        "parent_role": "vision",
        "child_role": "initiative",
        "min_children": 2
      },
      {
        "parent_role": "initiative",
        "child_role": "task",
        "min_children": 2
      }
    ],
    "architecture_constraints": [
      {
        "name": "stage-isolation",
        "description": "Each pipeline stage must be a separate module with a defined input/output type",
        "boundary_patterns": [
          {
            "pattern": "mod\\s+(ingestion|enrichment|routing|sink)",
            "kind": "must_exist",
            "file_glob": "src/lib.rs"
          }
        ]
      },
      {
        "name": "typed-events",
        "description": "Events must flow through typed structs, not raw JSON or strings",
        "boundary_patterns": [
          {
            "pattern": "struct\\s+Event",
            "kind": "must_exist",
            "file_glob": "src/**/*.rs"
          }
        ]
      },
      {
        "name": "error-boundaries",
        "description": "Each stage must define its own error type",
        "boundary_patterns": [
          {
            "pattern": "enum\\s+\\w+Error",
            "kind": "must_exist",
            "file_glob": "src/**/*.rs"
          }
        ]
      }
    ]
  },
  "verification": [
    {
      "name": "cargo-build",
      "command": "cargo build",
      "expected_exit_code": 0
    },
    {
      "name": "cargo-test",
      "command": "cargo test",
      "expected_exit_code": 0,
      "expected_stdout_contains": ["test result: ok"]
    },
    {
      "name": "cargo-clippy",
      "command": "cargo clippy -- -D warnings",
      "expected_exit_code": 0
    }
  ]
}
